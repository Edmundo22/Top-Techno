{
  "name": "top-techno-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend da aplicação TOP TECHNO",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec \"node -r @swc-node/register src/index.ts\"",
    "build": "swc src -d dist --strip-leading-paths",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mssql": "^11.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@swc-node/register": "^1.10.9",
    "@swc/cli": "^0.5.0",
    "@swc/core": "^1.9.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/mssql": "^9.1.5",
    "@types/node": "^22.9.0",
    "nodemon": "^3.1.7",
    "typescript": "^5.6.3"
  },
  "packageManager": "yarn@4.13.0"
}
