NODE_ENV=development
PORT=3333

# ===== Banco SQL Server =====
DB_SERVER=
DB_PORT=1433
DB_NAME=TOP_TECHNO
DB_USER=
DB_PASSWORD=
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=true

# ===== Autenticação =====
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

# ===== Cookie =====
COOKIE_NAME=tt_session
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# ===== CORS =====
CORS_ORIGIN=http://localhost:5173
